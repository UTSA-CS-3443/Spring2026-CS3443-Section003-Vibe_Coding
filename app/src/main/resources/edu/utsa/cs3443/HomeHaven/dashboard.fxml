<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25.0" style="-fx-padding: 25;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.utsa.cs3443.HomeHaven.controller.DashboardController">

    <!-- Title + Export Button Row -->
    <HBox alignment="CENTER_LEFT">
        <Label style="-fx-font-size: 26; -fx-font-weight: bold;" text="Dashboard"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleDownloadCsv"
                style="-fx-background-color: #4CAF50;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-padding: 8 18 8 18;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;"
                text="Download CSV"/>
    </HBox>

    <!-- Stat Cards -->
    <GridPane hgap="25">
        <columnConstraints>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0"
              style="-fx-background-color: #f4f4f4;
                     -fx-padding: 15;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
            <Label style="-fx-text-fill: gray;" text="Total Assets"/>
            <Label fx:id="lblAssetCount" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
        </VBox>

        <VBox GridPane.columnIndex="1"
              style="-fx-background-color: #fff3cd;
                     -fx-padding: 15;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
            <Label style="-fx-text-fill: #856404;" text="Due Soon"/>
            <Label fx:id="lblDueSoon" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
        </VBox>

        <VBox GridPane.columnIndex="2"
              style="-fx-background-color: #f8d7da;
                     -fx-padding: 15;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
            <Label style="-fx-text-fill: #721c24;" text="Overdue"/>
            <Label fx:id="lblOverdue" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
        </VBox>

        <VBox GridPane.columnIndex="3"
              style="-fx-background-color: #d1ecf1;
                     -fx-padding: 15;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
            <Label style="-fx-text-fill: #0c5460;" text="Expired"/>
            <Label fx:id="lblExpiredWarranties" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
        </VBox>
    </GridPane>

    <!-- Section Title -->
    <Label style="-fx-font-size: 16; -fx-font-weight: bold;" text="Recent Assets">
        <VBox.margin>
            <Insets top="10"/>
        </VBox.margin>
    </Label>

    <!-- List -->
    <ListView fx:id="recentList" prefHeight="180.0"
              style="-fx-background-radius: 12;
                     -fx-border-radius: 12;
                     -fx-border-color: #ddd;"/>

</VBox>
