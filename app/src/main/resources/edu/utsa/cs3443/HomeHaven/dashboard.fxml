<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.utsa.cs3443.HomeHaven.controller.DashboardController"
      prefHeight="400.0" prefWidth="600.0"
      spacing="20.0"
      style="-fx-padding: 20;">

    <children>
        <Label text="Dashboard" style="-fx-font-size: 20; -fx-font-weight: bold;"/>

        <GridPane hgap="20.0" vgap="10.0">
            <children>
                <Label text="Total Assets:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblAssetCount" text="0" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Due Soon:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblDueSoon" text="0" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Overdue:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="lblOverdue" text="0" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Expired Warranties:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="lblExpiredWarranties" text="0" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </children>
        </GridPane>
    </children>

</VBox>
