<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.utsa.cs3443.HomeHaven.controller.RemindersController"
      prefHeight="400.0" prefWidth="600.0"
      spacing="10.0"
      style="-fx-padding: 20;">

    <children>
        <Label text="Reminders" style="-fx-font-size: 20; -fx-font-weight: bold;"/>

        <!-- Toolbar -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Button text="+ Add"    onAction="#handleAdd"    fx:id="btnAdd"/>
            <Button text="✎ Edit"   onAction="#handleEdit"   fx:id="btnEdit"/>
            <Button text="✖ Remove" onAction="#handleRemove" fx:id="btnRemove"/>
        </HBox>

        <TableView fx:id="tblReminders" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colAsset"   text="Asset"    prefWidth="150"/>
                <TableColumn fx:id="colTitle"   text="Title"    prefWidth="160"/>
                <TableColumn fx:id="colType"    text="Type"     prefWidth="120"/>
                <TableColumn fx:id="colDueDate" text="Due Date" prefWidth="100"/>
                <TableColumn fx:id="colStatus"  text="Status"   prefWidth="100"/>
            </columns>
        </TableView>
    </children>

</VBox>
