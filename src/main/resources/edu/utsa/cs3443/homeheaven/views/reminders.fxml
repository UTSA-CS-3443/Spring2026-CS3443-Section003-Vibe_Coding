<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.utsa.cs3443.homeheaven.RemindersController"
      spacing="10">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label text="Reminders" style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <ListView fx:id="reminderList" prefHeight="300" />

    <HBox spacing="10">
        <TextField fx:id="titleField" promptText="Reminder title" />
        <DatePicker fx:id="dueDatePicker" />
        <ChoiceBox fx:id="typeChoice" />
        <Button fx:id="addButton" text="Add" />
    </HBox>

</VBox>